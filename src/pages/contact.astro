---
import ContactFormCore from "@/components/contact/ContactFormCore.astro";
import Base from "@/layouts/Base.astro";
import ProtonLogo from "@/assets/images/brands/proton.svg";
import ProtonDriveLogo from "@/assets/images/brands/protondrive.svg";
---

<Base
  title="Contact"
  description="Get in touch with Secunit Mercantile. Tell us about your business challenges and we'll show you how we can help."
>
  <section class="py-6 md:py-8">
    <div class="container">
      <div
        class="mx-auto max-w-3xl overflow-hidden rounded-2xl bg-gradient-to-b from-white to-slate-50 dark:from-[#111820] dark:to-[#0c1018]"
      >
        <div class="px-5 py-5 md:px-6 md:py-6">
          <div class="text-center">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#20E3B2]">Contact</p>
            <h1 class="mt-2 text-3xl font-extrabold text-dark dark:text-white md:text-4xl">Let's Talk</h1>
            <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-body dark:text-gray-300">
              Tell us a bit about your business and what you're looking to accomplish. We'll get back to you within one
              business day.
            </p>
          </div>

          <div
            class="mt-5 rounded-lg border border-gray-200/60 bg-slate-50/80 p-4 dark:border-white/[0.06] dark:bg-white/[0.03]"
            role="region"
            aria-label="Email authenticity and PGP keys"
          >
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <div class="flex items-center gap-3">
                <ProtonLogo class="h-8 w-auto" />
                <div>
                  <p class="text-sm font-semibold text-dark dark:text-white">We care about privacy.</p>
                  <p class="text-xs text-body dark:text-gray-300">
                    We use the Proton platform for secure communications and publish our keys so you can validate
                    authenticity.
                  </p>
                </div>
              </div>
              <div class="flex flex-shrink-0 flex-wrap gap-2">
                <a
                  href="/security/ecc.txt"
                  class="cursor-pointer rounded-md border border-[#20E3B2]/50 px-3 py-1.5 text-xs font-semibold text-[#20E3B2] transition duration-200 hover:bg-[#20E3B2]/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#20E3B2]/40"
                >
                  ECC public key
                </a>
                <a
                  href="/security/rsa.txt"
                  class="cursor-pointer rounded-md border border-[#20E3B2]/50 px-3 py-1.5 text-xs font-semibold text-[#20E3B2] transition duration-200 hover:bg-[#20E3B2]/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#20E3B2]/40"
                >
                  RSA public key
                </a>
              </div>
            </div>
            <div class="mt-5 border-t border-gray-200/60 pt-5 dark:border-white/[0.08]">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-3">
                <ProtonDriveLogo class="h-6 w-auto shrink-0" />
                <p class="text-xs text-body dark:text-gray-300">
                  Need to send us a file securely? Drop it here:
                  <a
                    href="https://drive.proton.me/urls/AEJE36XH8G#kD56WxZRdyjP"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-semibold text-[#20E3B2] underline underline-offset-2 transition hover:text-[#1bffce] hover:no-underline"
                  >
                    Proton Drive secure drop
                  </a>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-12 pt-4 md:pb-16 md:pt-6">
    <div class="container">
      <div class="mx-auto max-w-3xl">
        <div
          class="rounded-2xl border border-gray-200/90 bg-white/85 p-6 shadow-lg backdrop-blur-md dark:border-white/10 dark:bg-white/5 md:p-8"
        >
          <ContactFormCore
            submitClass="w-full rounded-xl bg-[#20E3B2] px-5 py-3 text-sm font-semibold text-slate-900 transition duration-200 hover:-translate-y-0.5 hover:bg-[#1bffce] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#20E3B2]/40 disabled:cursor-not-allowed disabled:opacity-60"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section-sm bg-gray-50 dark:bg-gray-800/50">
    <div class="container">
      <div class="mx-auto max-w-3xl">
        <div class="grid gap-8 md:grid-cols-2">
          <div class="text-center">
            <div
              class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary dark:text-darkmode-primary"
            >
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <h3 class="font-bold text-dark dark:text-white">Prefer email?</h3>
            <a href="mailto:hello@secunit.io" class="mt-1 text-primary hover:underline dark:text-darkmode-primary">
              hello@secunit.io
            </a>
          </div>

          <div class="text-center">
            <div
              class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary dark:text-darkmode-primary"
            >
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <h3 class="font-bold text-dark dark:text-white">Location</h3>
            <p class="mt-1 text-body dark:text-darkmode-body">Charlotte, NC</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Remote-first — we work with clients nationwide</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
